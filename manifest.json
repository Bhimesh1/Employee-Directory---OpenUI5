{
  "_version": "1.60.0",
  "sap.app": {
    "id": "employee.directory",
    "type": "application",
    "title": "Employee Directory",
    "description": "A simple employee directory built with OpenUI5."
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "dependencies": {
      "minUI5Version": "1.120.0",
      "libs": {
        "sap.m": {}
      }
    },
    "rootView": {
      "viewName": "employee.directory.view.App",
      "type": "XML",
      "id": "app",
      "async": true
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "employee.directory.view",
        "controlId": "app",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        {
          "pattern": "",
          "name": "employeeList",
          "target": "employeeList"
        },
        {
          "pattern": "employees/{employeeId}",
          "name": "employeeDetail",
          "target": "employeeDetail"
        }
      ],
      "targets": {
        "employeeList": {
          "viewName": "EmployeeList",
          "viewId": "employeeList"
        },
        "employeeDetail": {
          "viewName": "EmployeeDetail",
          "viewId": "employeeDetail"
        }
      }
    }
  }
}