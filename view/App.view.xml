<mvc:View
  controllerName="employee.directory.controller.App"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  displayBlock="true">

  <App>
    <Page title="Employee Directory">
      <content>
        <List
          id="employeeList"
          items="{/employees}"
          noDataText="No employees found">

          <StandardListItem
            title="{name}"
            description="{department}"
            info="{role}" />

        </List>
      </content>
    </Page>
  </App>

</mvc:View>